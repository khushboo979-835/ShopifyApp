{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/.next",
    "frontend/.next",
    "backend/dist"
  ]
}
